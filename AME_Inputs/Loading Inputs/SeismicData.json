{
  "$id": "https://raw.githubusercontent.com/mkawahara22/hypar-schemas/main/AME_Inputs/SeismicData.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Seismic Data and Information",
  "title": "SeismicData",
  "x-namespace": "Elements",
  "type": ["object", "null"],
  "allOf": [{ "$ref": "https://hypar.io/Schemas/Element.json" }],
  "properties": {
    "Design Parameters": {
      "type": "object",
      "$hyparStyle": "row",
      "properties": {
        "Soil Site Classification": {
          "type": "string",
          "$hyparOrder": 0,
          "enum": ["A", "B", "C", "D", "E", "F"],
          "default": "D"
        },
        "SDS": {
          "default": 0.05,
          "description": "Spectral response acceleration parameter at short periods",
          "type": "number",
          "$hyparOrder": 1,
          "minimum": 0
        },
        "SD1": {
          "default": 0.044,
          "description": "Spectral response acceleration parameter at 1 second periods",
          "type": "number",
          "$hyparOrder": 2,
          "minimum": 0
        },
        "S1": {
          "default": 0.028,
          "description": "Measured acceleration parameter at 1 second periods",
          "type": "number",
          "$hyparOrder": 3,
          "minimum": 0
        },
        "Ie": {
          "type": "number",
          "description": "Seismic Importance factor, typically 1.0 for Risk Category II",
          "default": 1.0,
          "$hyparOrder": 4
        },
        "VerticalSeismicLoad_PSF": {
          "description": "Vertical Seismic Load applied to the building in PSF",
          "type": "number"
        },
        "Cs": {
          "type": "number",
          "description": "Seismic Response Coefficient"
        }
      }
    },
    "Lateral System Selection": {
      "type": "object",
      "$hyparStyle": "row",
      "properties": {
        "Lateral Wall System": {
          "type": "string",
          "$hyparOrder": 4,
          "enum": [
            "Special Reinforced Concrete Shear Walls",
            "Ordinary Reinforced Concrete Shear Walls",
            "Intermediate Precast Shear Walls",
            "Ordinary Precast Shear Walls"
          ],
          "default": "Ordinary Reinforced Concrete Shear Walls"
        },
        "Lateral Frame System": {
          "type": "string",
          "$hyparOrder": 5,
          "enum": [
            "Steel Systems Not Specifically Detailed for Seismic Systems",
            "Steel Buckling-Restrained Braced Frames",
            "Steel Eccentrically Braced Frames",
            "Steel Special Concentrically Braced Frames",
            "Steel Ordinary Concentrically Braced Frames",
            "Steel Special Moment Frames",
            "Steel Special Truss Moment Frames",
            "Steel Intermediate Moment Frames",
            "Steel Ordinary Moment Frames"
          ],
          "default": "Steel Systems Not Specifically Detailed for Seismic Systems"
        }
      }
    },
    "SeismicResistanceFactors": {
      "type": "object",
      "description": "Factors from Seismic Table",
      "properties": {
        "R_Factor": {
          "type": "number",
          "description": "R (Response Modification Factor): Scales down the elastic seismic forces to design level forces by accounting for ductility, overstrength, and energy dissipation capacity of the lateral system."
        },
        "Omega_Factor": {
          "type": "number",
          "description": "Ω₀ (Overstrength Factor): Amplifies design forces for certain elements and connections to reflect the probable overstrength of the system so those components do not fail before the yielding mechanism."
        },
        "C_Factor": {
          "type": "number",
          "description": "Cᵈ (Deflection Amplification Factor): Scales up calculated elastic story drifts to estimate inelastic (expected) drift demands for checking deformation related limits and detailing."
        }
      }
    }
  },
  "additionalProperties": false
}
